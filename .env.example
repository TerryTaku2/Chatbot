# Copy this file to .env and fill in your real values
# NEVER commit .env to version control

# REQUIRED — Postgres connection string (Render, Railway, Supabase, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional — base directory for uploaded product images. On Render, point this
# at your mounted persistent disk (e.g. /var/data) so uploads survive redeploys.
# Defaults to the local ./static folder when unset.
DATA_DIR=

WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
PHONE_NUMBER_ID=your_phone_number_id_here

# REQUIRED — server will refuse to start if missing. Used to verify Meta's
# X-Hub-Signature-256 header on incoming /webhook requests; without it, any
# request with a spoofed sender phone number (including the admin's) would be
# accepted as genuine.
WHATSAPP_APP_SECRET=your_facebook_app_secret_here

BASE_URL=https://your-ngrok-or-domain.com
VERIFY_TOKEN=generate_a_strong_random_string

VENDOR_NUMBERS=2637XXXXXXXXX,2637XXXXXXXXX
ADMIN_PHONE=2637XXXXXXXXX

TTECH_CONNECT_URL=https://your-accommodation-app.onrender.com

# API key sent as X-API-Key header — set the same value on the T-Tech Connect1 side
TTECH_API_KEY=generate_a_strong_random_key_here

# REQUIRED — server will refuse to start if missing. Used to verify incoming
# webhooks FROM T-Tech Connect1 (HMAC-SHA256 secret) at /webhooks/property.
TTECH_WEBHOOK_SECRET=another_strong_random_secret_here

# Optional — where the accommodation blueprint sends its outbound webhooks
# (booking.confirmed, enquiry.created, etc). Defaults to BASE_URL since the
# blueprint now runs in this same process — only set this if you split it
# back out into a separate service.
CHATBOT_BASE_URL=

CONTACT_PHONE=+263 77 XXX XXXX
CONTACT_EMAIL=your@email.com
CONTACT_WEBSITE=https://your-website.co.zw
CONTACT_LOCATION=Harare, Zimbabwe

# REQUIRED — server will refuse to start if these are missing or empty
FLASK_SECRET_KEY=generate_a_long_random_string_here
SHOP_ADMIN_PASSWORD=change_this_to_a_strong_password

# REQUIRED — used by the accommodation blueprint to send verification, reset,
# and notification emails via Resend (https://resend.com). Without it, those
# emails fail silently and users can get stuck unable to verify their account.
RESEND_API_KEY=re_your_resend_api_key_here

# Optional — protects the /cron/* endpoints from public access
CRON_SECRET=generate_a_random_secret_here

# Optional — seller-paid marketing campaigns (Facebook Graph API poster above
# also needs FACEBOOK_PAGE_TOKEN/FACEBOOK_PAGE_ID set). Each platform below is
# independently optional — unset ones are simply skipped when posting.
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# X (Twitter) OAuth1 user-context credentials for the business account
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
