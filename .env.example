# Copy this file to .env and fill in your real values
# NEVER commit .env to version control

# REQUIRED — Postgres connection string (Render, Railway, Supabase, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional — base directory for uploaded product images. On Render, point this
# at your mounted persistent disk (e.g. /var/data) so uploads survive redeploys.
# Defaults to the local ./static folder when unset.
DATA_DIR=

WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_APP_SECRET=your_facebook_app_secret_here

BASE_URL=https://your-ngrok-or-domain.com
VERIFY_TOKEN=generate_a_strong_random_string

VENDOR_NUMBERS=2637XXXXXXXXX,2637XXXXXXXXX
ADMIN_PHONE=2637XXXXXXXXX

TTECH_CONNECT_URL=https://your-accommodation-app.onrender.com

# API key sent as X-API-Key header — set the same value on the T-Tech Connect1 side
TTECH_API_KEY=generate_a_strong_random_key_here

# Used to verify incoming webhooks FROM T-Tech Connect1 (HMAC-SHA256 secret)
TTECH_WEBHOOK_SECRET=another_strong_random_secret_here

CONTACT_PHONE=+263 77 XXX XXXX
CONTACT_EMAIL=your@email.com
CONTACT_WEBSITE=https://your-website.co.zw
CONTACT_LOCATION=Harare, Zimbabwe

# REQUIRED — server will refuse to start if these are missing or empty
FLASK_SECRET_KEY=generate_a_long_random_string_here
ADMIN_PASSWORD=change_this_to_a_strong_password

# Optional — protects the /cron/* endpoints from public access
CRON_SECRET=generate_a_random_secret_here
